<div class="min-h-screen bg-gradient-to-br from-orange-500 via-orange-400 to-orange-300 flex items-center justify-center px-4 py-16">

  <div class=" max-w-md bg-white/90 backdrop-blur-md rounded-2xl shadow-xl p-8">

    <!-- タイトル -->
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold text-slate-800 mb-2">
        ユーザー登録
      </h2>
      <p class="text-sm text-slate-500">
        Rails学習のアウトプットを共有して、コミュニティに参加しましょう。
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>

      <!-- エラーメッセージ -->
      <%= render "devise/shared/error_messages", resource: resource %>

      <!-- メールアドレス -->
      <div class="mb-5">
        <%= f.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1" %>

        <div class="relative">
          <%= f.email_field :email,
            autofocus: true,
            autocomplete: "email",
            placeholder: "your@email.com",
            class: "w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400 transition" %>
        </div>
      </div>

      <!-- パスワード -->
      <div class="mb-5">
        <%= f.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-1" %>

        <% if @minimum_password_length %>
          <p class="text-xs text-slate-400 mb-1">
            （<%= @minimum_password_length %>文字以上）
          </p>
        <% end %>

        <%= f.password_field :password,
          autocomplete: "new-password",
          placeholder: "••••••••",
          class: "w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400 transition" %>
      </div>

      <!-- パスワード確認 -->
      <div class="mb-6">
        <%= f.label :password_confirmation, "パスワード（確認）", class: "block text-sm font-medium text-slate-700 mb-1" %>

        <%= f.password_field :password_confirmation,
          autocomplete: "new-password",
          placeholder: "••••••••",
          class: "w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400 transition" %>
      </div>

      <!-- ボタン -->
      <div class="mb-6">
        <%= f.submit "新規登録",
          class: "w-full bg-orange-500 hover:bg-orange-600 text-white font-semibold py-2.5 rounded-lg transition shadow-md hover:shadow-lg" %>
      </div>

    <% end %>

    <!-- ログインリンク -->
    <div class="text-center border-t border-slate-100 pt-6">
      <p class="text-sm text-slate-500">
        すでにアカウントをお持ちですか？
        <%= link_to "ログインはこちら", new_session_path(resource_name),
          class: "text-orange-500 font-medium hover:text-orange-600 transition" %>
      </p>
    </div>

  </div>
</div>

<%= render "devise/shared/links" %>
