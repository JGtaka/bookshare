<header class="sticky top-0 z-50 w-full border-b border-primary/10 bg-white/80 backdrop-blur-md">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <div class="flex items-center gap-2">
        <div class="flex h-8 w-8 items-center justify-center rounded bg-primary text-white">
          <span class="material-symbols-outlined text-xl">menu_book</span>
        </div>
        <h1 class="text-xl font-bold tracking-tight">
          RUNTEQ <span class="text-primary">Output</span>
        </h1>
      </div>

      <div class="flex items-center gap-4">
        <% if user_signed_in? %>
          <%= link_to 'ログアウト', destroy_user_session_path, data: { turbo_method: :delete },class: "rounded-lg px-4 py-2 text-sm font-bold text-slate-700 hover:bg-primary/10 transition-colors" %>
          <%= link_to '記事一覧', articles_path, class: "rounded-lg px-4 py-2 text-sm font-bold text-slate-700 hover:bg-primary/10 transition-colors" %>
          <%= link_to '新規記事作成', new_article_path, class: "rounded-lg px-4 py-2 text-sm font-bold text-slate-700 hover:bg-primary/10 transition-colors" %>
          <div class="hidden sm:flex items-center gap-2 rounded-full border border-slate-200 bg-white/70 px-3 py-1 text-sm shadow-sm">
            <span class="material-symbols-outlined text-slate-400 text-base">
              account_circle
            </span>
            <span class="text-slate-600">
              <%= current_user.email %>
            </span>
          </div>
        <% else %>  
          <%= link_to "ログイン",
            new_user_session_path,
            class: "rounded-lg px-4 py-2 text-sm font-bold text-slate-700 hover:bg-primary/10 transition-colors" %>

          <%= link_to "新規登録",
            new_user_registration_path,
            class: "rounded-lg bg-primary px-5 py-2 text-sm font-bold text-white hover:opacity-90 transition-colors" %>
        <% end %>
      </div>

    </div>
  </div>
</header>