<div class="max-w-4xl mx-auto px-4 py-8">
  
  <!-- ページヘッダー -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-800 mb-2">
      記事の作成
    </h1>
    <p class="text-slate-500">
      Rails学習のアウトプットをRUNTEQコミュニティに共有しましょう。
    </p>
  </div>

  <%= form_with model: @article, local: true, class: "space-y-6" do |f| %>
    <%= render 'shared/error_messages', object: f.object %>

    <!-- タイトル -->
    <div>
      <%= f.label :title, "タイトル", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_field :title,
          placeholder: "Rails学習に関するタイトルを入力してください...",
          class: "w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-700 placeholder-slate-400
                 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400" %>
    </div>

    <!-- カリキュラムセクション -->
    <div class="bg-slate-50 border border-slate-200 rounded-xl p-4">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-orange-500 font-semibold">school</span>
        <span class="text-sm text-slate-700">カリキュラムを選択</span>
      </div>

      <%= f.text_field :curriculum,
          placeholder: "該当するカリキュラムを選択してください",
          class: "w-full rounded-lg border border-slate-200 px-4 py-2 text-slate-700 placeholder-slate-400
                 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400" %>

      <p class="text-xs text-slate-400 mt-2">
        投稿内容を適切なカリキュラムに分類することで、他の学習者が探しやすくなります。
      </p>
    </div>

   
    <!-- 本文 -->
    <div>
      <%= f.label :body, "本文 (MARKDOWN記法)", class: "block text-sm font-semibold text-slate-700 mb-2" %>
      <%= f.text_area :body,
          rows: 12,
          placeholder: "技術的な内容をここに記入してください。Markdown記法が利用可能です。",
          class: "w-full rounded-xl border border-slate-200 px-4 py-3 text-slate-700 placeholder-slate-400
                 focus:outline-none focus:ring-2 focus:ring-orange-400 focus:border-orange-400
                 font-mono text-sm" %>
    </div>

    <!-- ボタンエリア -->
    <div class="flex justify-between items-center pt-4">
      <%= link_to "キャンセル", articles_path, class: "text-sm text-slate-500 hover:text-slate-700" %>
        <%= f.submit "投稿する", 
            class: "bg-orange-500 hover:bg-orange-600 text-white font-semibold px-6 py-2 rounded-lg transition-colors shadow-sm" %>
      </div>
    </div>

  <% end %>
</div>